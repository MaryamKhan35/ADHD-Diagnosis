# Backend Environment Configuration
# EEG ADHD Detection System

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=eeg_adhd_detection

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# File Upload Configuration
MAX_UPLOAD_SIZE=524288000  # 500MB in bytes
UPLOAD_DIRECTORY=./uploads/eeg_files
REPORTS_DIRECTORY=./uploads/reports

# Model Configuration
MODEL_PATH=../model/cnn_frozen.pth
MODEL_DEVICE=cpu  # Change to 'cuda' if GPU available

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/eeg_adhd_api.log

# Email Configuration (Optional - for future notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AWS S3 Configuration (Optional - for cloud storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=eeg-adhd-reports
AWS_S3_REGION=us-east-1
